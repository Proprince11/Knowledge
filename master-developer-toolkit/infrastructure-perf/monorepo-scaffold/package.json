{
  "name": "master-developer-toolkit",
  "version": "1.0.0",
  "private": true,
  "description": "Unified high-performance fullstack monorepo coordinating media-AI apps, SaaS shells, and shared infrastructure packages.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps-media-ai/*",
    "apps-saas-shells/*",
    "infrastructure-perf/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ci": "turbo run test -- --run --coverage",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md,yml}\"",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "gateway:start": "node infrastructure-perf/api-gateway-redis/gateway.js",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "eslint": "^9.12.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  }
}
