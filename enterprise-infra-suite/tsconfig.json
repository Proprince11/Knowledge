{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2021"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "event-driven-architecture/**/*.ts",
    "high-performance-data/**/*.ts",
    "zero-trust-security/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
