{
  "name": "enterprise-infra-suite",
  "version": "1.0.0",
  "description": "Enterprise Infrastructure, Event-Driven & Zero-Trust Security master layer: AMQP pub/sub, async service mesh, Redis caching, full-text fuzzy search, and a hardened API gateway with AES-256-GCM crypto utilities.",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo:producer": "node event-driven-architecture/message-broker/producer.js",
    "demo:consumer": "node event-driven-architecture/message-broker/consumer-worker.js",
    "demo:cache": "node high-performance-data/redis-cache-layer/cache-manager.js",
    "demo:search": "node high-performance-data/optimized-search/search-indexer.js",
    "demo:proxy": "node zero-trust-security/api-armor-proxy/proxy-shield.js",
    "demo:crypto": "ts-node zero-trust-security/crypto-vault-utils/secure-crypto.ts"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
