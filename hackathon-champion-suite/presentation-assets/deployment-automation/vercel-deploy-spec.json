{
  "schemaRef": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "hackathon-champion-suite",
  "public": true,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://localhost:4000/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "github": { "silent": true, "autoAlias": true },
  "_netlify_equivalent": {
    "build": { "command": "npm run build", "publish": "dist" },
    "redirects": [{ "from": "/*", "to": "/index.html", "status": 200 }]
  },
  "_one_click_deploy": {
    "vercel": "Run: npx vercel --prod   (from repo root, after npm install)",
    "netlify": "Run: npx netlify deploy --prod --dir=dist"
  }
}
