{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "edge-computing-runtime/**/*.ts",
    "chaos-engineering/**/*.ts",
    "crypto-decentralized-auth/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
